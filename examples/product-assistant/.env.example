# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.
#
# How to get these values:
#   1. Sign up at https://try.runagents.io
#   2. Log in → Settings → API Keys
#   3. Copy your Workspace URL and API Key

# ─── RunAgents Platform ─────────────────────────────────────────────────────

# Your workspace URL (from the console — Settings → Workspace)
# Format: https://<your-workspace-id>.try.runagents.io
RUNAGENTS_ENDPOINT=https://YOUR_WORKSPACE_ID.try.runagents.io

# Your API key (from the console — Settings → API Keys)
# Format: ra_ws_...
RUNAGENTS_API_KEY=ra_ws_YOUR_API_KEY_HERE

# Your namespace (usually "default" for personal workspaces)
RUNAGENTS_NAMESPACE=default

# ─── LLM (only needed for local dev without platform gateway) ───────────────

# Your OpenAI API key — only required if running agent.py directly
# (python agent.py) without the platform LLM gateway.
# The deployed agent on the platform NEVER uses this key —
# the platform injects its own gateway credentials.
#
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
