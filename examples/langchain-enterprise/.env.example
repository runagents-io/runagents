# Copy to .env — never commit this file.

# ─── RunAgents Platform ─────────────────────────────────────────────────────
# From console → Settings → API Keys
RUNAGENTS_ENDPOINT=https://YOUR_WORKSPACE_ID.try.runagents.io
RUNAGENTS_API_KEY=ra_ws_YOUR_KEY_HERE
RUNAGENTS_NAMESPACE=default

# ─── LLM (local dev only) ───────────────────────────────────────────────────
# Only needed for: python agent.py (direct test without platform gateway)
# The deployed agent routes through the platform gateway — no key needed.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# ─── Identity Provider (optional — for testing JWT validation) ─────────────
# Your JWKS endpoint for verifying JWTs at the ingress.
# Example (Auth0): https://YOUR_TENANT.auth0.com/.well-known/jwks.json
# Example (Okta):  https://YOUR_DOMAIN.okta.com/oauth2/v1/keys
# JWKS_URI=https://YOUR_PROVIDER/.well-known/jwks.json
